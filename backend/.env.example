# ============================================
# SecurePay NeoBank Backend - Environment Variables
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=localhost

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/securepay_neobank?retryWrites=true&w=majority
MONGODB_DB_NAME=securepay_neobank

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_in_production
JWT_REFRESH_EXPIRE=7d

# Session Configuration
SESSION_SECRET=your_session_secret_key_change_in_production

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@securepay.com

# Razorpay Integration
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Security
BCRYPT_ROUNDS=12
PASSWORD_RESET_TOKEN_EXPIRY=3600
OTP_EXPIRY=600
OTP_RESEND_LIMIT=5

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_AUTH_REQUESTS=5

# API Configuration
API_BASE_URL=http://localhost:5000/api
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# Features
FRAUD_DETECTION_ENABLED=true
FRAUD_DETECTION_SERVICE_URL=http://localhost:8000
ENABLE_2FA=true
ENABLE_DEVICE_TRACKING=true

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png
UPLOAD_DIR=uploads

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Transaction Limits
DAILY_TRANSFER_LIMIT=100000
MONTHLY_TRANSFER_LIMIT=500000
SINGLE_TRANSACTION_LIMIT=50000
MIN_TRANSACTION_AMOUNT=1

# KYC Settings
KYC_VERIFICATION_TIMEOUT=86400
KYC_DOCUMENT_RETENTION=2592000

# Audit Settings
AUDIT_LOG_RETENTION_DAYS=90

# Cache Settings
CACHE_TTL=3600
SESSION_TTL=86400
